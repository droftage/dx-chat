    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.0.0",
    "@tanstack/react-query": "^5.90.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "antd": "^6.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
